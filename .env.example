APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Resume PDF rendering (Spatie Browsershot -> headless Chromium via Puppeteer).
# All optional: defaults work when `node` is on PATH and `npm install` has put
# puppeteer (with its bundled Chromium) in this project's node_modules. Override
# per environment (e.g. on the VPS) — see config/resumepdf.php.
# RESUME_PDF_NODE_BINARY=/usr/bin/node
# RESUME_PDF_NPM_BINARY=/usr/bin/npm
# RESUME_PDF_CHROME_PATH=/usr/bin/chromium-browser
# RESUME_PDF_NODE_MODULES_PATH=/var/www/startyourstory_api
# RESUME_PDF_NO_SANDBOX=true
# RESUME_PDF_TIMEOUT=60

# CA Library separate database (host/user/pass default to main DB_* values)
CA_LIB_DB_DATABASE=ca_library

# CA Library Google Sign-In (students only; SYS auth unaffected).
# OAuth 2.0 Client ID from Google Cloud Console. Public by design — it also
# ships in the frontend as VITE_GOOGLE_CLIENT_ID. Leave blank to disable the
# "Continue with Google" button.
GOOGLE_CLIENT_ID=

# Cashfree Payment Gateway (optional; PhonePe remains the default).
# Leave blank to keep Cashfree unavailable — the app defaults to PhonePe and only
# uses Cashfree when the Admin Panel selects it. If selected while any of these
# are blank, payment initiation fails loudly with a clear configuration error
# (it never silently falls back). Populate with sandbox values first, then prod.
#   CASHFREE_BASE_URL  sandbox: https://sandbox.cashfree.com/pg
#                      production: https://api.cashfree.com/pg
#   CASHFREE_MODE      sandbox | production  (also drives the frontend JS SDK)
#   CASHFREE_API_VERSION  Cashfree "x-api-version" date, e.g. 2023-08-01
# The same secret key verifies webhooks (HMAC) — no separate webhook secret.
CASHFREE_APP_ID=
CASHFREE_SECRET_KEY=
CASHFREE_API_VERSION=
CASHFREE_BASE_URL=
CASHFREE_MODE=
